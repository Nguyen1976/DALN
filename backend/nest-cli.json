{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "monorepo": true,
  "projects": {
    "chat": {
      "type": "application",
      "root": "apps/chat",
      "entryFile": "main",
      "sourceRoot": "apps/chat/src",
      "compilerOptions": {
        "assets": [
          {
            "include": "generated/**/*",
            "outDir": "dist/apps/chat/apps/chat/src"
          }
        ],
        "tsConfigPath": "apps/chat/tsconfig.app.json"
      }
    },
    "common": {
      "type": "library",
      "root": "libs/common",
      "entryFile": "index",
      "sourceRoot": "libs/common/src",
      "compilerOptions": {
        "tsConfigPath": "libs/common/tsconfig.lib.json"
      }
    },
    "constant": {
      "type": "library",
      "root": "libs/constant",
      "entryFile": "index",
      "sourceRoot": "libs/constant/src",
      "compilerOptions": {
        "tsConfigPath": "libs/constant/tsconfig.lib.json"
      }
    },
    "logger": {
      "type": "library",
      "root": "libs/logger",
      "entryFile": "index",
      "sourceRoot": "libs/logger/src",
      "compilerOptions": {
        "tsConfigPath": "libs/logger/tsconfig.lib.json"
      }
    },
    "mailer": {
      "type": "library",
      "root": "libs/mailer",
      "entryFile": "index",
      "sourceRoot": "libs/mailer/src",
      "compilerOptions": {
        "tsConfigPath": "libs/mailer/tsconfig.lib.json"
      }
    },
    "notification": {
      "type": "application",
      "root": "apps/notification",
      "entryFile": "main",
      "sourceRoot": "apps/notification/src",
      "compilerOptions": {
        "assets": [
          {
            "include": "generated/**/*",
            "outDir": "dist/apps/notification/apps/notification/src"
          }
        ],
        "tsConfigPath": "apps/notification/tsconfig.app.json"
      }
    },
    "realtime-gateway": {
      "type": "application",
      "root": "apps/realtime-gateway",
      "entryFile": "main",
      "sourceRoot": "apps/realtime-gateway/src",
      "compilerOptions": {
        "tsConfigPath": "apps/realtime-gateway/tsconfig.app.json"
      }
    },
    "recommendation": {
      "type": "application",
      "root": "apps/recommendation",
      "entryFile": "main",
      "sourceRoot": "apps/recommendation/src",
      "compilerOptions": {
        "tsConfigPath": "apps/recommendation/tsconfig.app.json"
      }
    },
    "redis": {
      "type": "library",
      "root": "libs/redis",
      "entryFile": "index",
      "sourceRoot": "libs/redis/src",
      "compilerOptions": {
        "tsConfigPath": "libs/redis/tsconfig.lib.json"
      }
    },
    "storage-r2": {
      "type": "library",
      "root": "libs/storage-r2",
      "entryFile": "index",
      "sourceRoot": "libs/storage-r2/src",
      "compilerOptions": {
        "tsConfigPath": "libs/storage-r2/tsconfig.lib.json"
      }
    },
    "user": {
      "type": "application",
      "root": "apps/user",
      "entryFile": "main",
      "sourceRoot": "apps/user/src",
      "compilerOptions": {
        "assets": [
          {
            "include": "generated/**/*",
            "outDir": "dist/apps/user/apps/user/src"
          }
        ],
        "tsConfigPath": "apps/user/tsconfig.app.json"
      }
    },
    "util": {
      "type": "library",
      "root": "libs/util",
      "entryFile": "index",
      "sourceRoot": "libs/util/src",
      "compilerOptions": {
        "tsConfigPath": "libs/util/tsconfig.lib.json"
      }
    }
  }
}