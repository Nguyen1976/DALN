generator client {
  provider = "prisma-client-js"
  output = "../src/generated"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model UserSnapshot {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String   @unique @db.ObjectId
  username  String
  fullName  String
  avatar    String?
  bio       String?
  interests String[] @default([])
  location  Json?
  isActive  Boolean  @default(true)
  lastSeen  DateTime?
  syncedAt  DateTime @default(now())
  createdAt DateTime @default(now())

  @@index([interests])
  @@index([location], map: "location_2dsphere")
  @@index([isActive, lastSeen])
  @@index([syncedAt])
}

model InterestTag {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  slug      String   @unique
  label     String
  emoji     String
  category  String
  order     Int      @default(0)
  isActive  Boolean  @default(true)
}

model RecommendationResult {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  userId       String   @unique @db.ObjectId
  topK         Int      @default(100)
  candidates   Json
  // features: full candidate features pool used to generate ranking (audit/debug)
  features     Json?
  dayVersion   Int
  expiresAt    DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([expiresAt])
  @@index([dayVersion])
}

